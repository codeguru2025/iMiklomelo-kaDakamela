# =============================================================================
# iMiklomelo kaDakamela Cultural Festival - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running the app.

# ---------- Database (Required) ----------
# Transaction pooler connection string (used by the app at runtime)
# Found in DO Database dashboard → Connection Details → Connection Pools
DATABASE_URL=postgresql://user:password@pool-host:25061/dbname?sslmode=require

# Direct connection string (used for migrations ONLY — bypasses pooler)
# Found in DO Database dashboard → Connection Details → Public Network
DATABASE_DIRECT_URL=postgresql://user:password@host:25060/dbname?sslmode=require

# ---------- App URL (Required) ----------
# The public URL of your deployed app (no trailing slash)
APP_URL=https://your-domain.com

# ---------- Server ----------
PORT=5000
NODE_ENV=production
SESSION_SECRET=generate-a-long-random-string-here

# ---------- Google OAuth (Required for admin login) ----------
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://your-domain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---------- Admin Access (Fallback) ----------
# Secret key sent via x-admin-key header to access admin endpoints (dev fallback)
ADMIN_SECRET_KEY=your-admin-secret-key

# ---------- Paynow Payment Gateway (Required for payments) ----------
PAYNOW_INTEGRATION_ID=your-paynow-integration-id
PAYNOW_INTEGRATION_KEY=your-paynow-integration-key

# ---------- Resend Email Service (Required for emails) ----------
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ---------- DigitalOcean Spaces (Required for file uploads) ----------
# Create a Space at https://cloud.digitalocean.com/spaces
DO_SPACES_KEY=your-spaces-access-key
DO_SPACES_SECRET=your-spaces-secret-key
DO_SPACES_BUCKET=dakamela-uploads
DO_SPACES_REGION=lon1
DO_SPACES_ENDPOINT=https://lon1.digitaloceanspaces.com
# Optional: Enable CDN for faster delivery (set up in DO Spaces settings)
DO_SPACES_CDN_ENDPOINT=https://dakamela-uploads.lon1.cdn.digitaloceanspaces.com
